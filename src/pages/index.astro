<script is:inline>
/* ░░ WEBFORGE · capa de experiencia (orquestada · performante · accesible) ░░ */
(function(){
  var rm = matchMedia('(prefers-reduced-motion: reduce)').matches;
  var fine = matchMedia('(pointer:fine)').matches;
  if(rm) return; // todo degrada: sin movimiento, la página queda íntegra

  /* 1 · HÉROE (momento dominante): spotlight reactivo + zoom de profundidad */
  var sticky=document.querySelector('.sticky'), scene=document.getElementById('scene'), vid=document.getElementById('arcaVid');
  if(sticky && fine){
    sticky.addEventListener('pointermove',function(e){
      var r=sticky.getBoundingClientRect();
      sticky.style.setProperty('--sx',((e.clientX-r.left)/r.width*100).toFixed(1)+'%');
      sticky.style.setProperty('--sy',((e.clientY-r.top)/r.height*100).toFixed(1)+'%');
    },{passive:true});
  }
  if(scene && vid){
    window.addEventListener('scroll',function(){
      var total=scene.offsetHeight-window.innerHeight;
      var p=total>0?Math.max(0,Math.min(1,(-scene.getBoundingClientRect().top)/total)):0;
      vid.style.setProperty('--vzoom',(1.04+p*0.10).toFixed(3));
    },{passive:true});
  }

  if(!fine) return; // cursor y magnéticos solo en desktop con puntero fino

  /* 2 · Cursor de marca (anillo con lag + punto) */
  var ring=document.querySelector('.cursor'), dot=document.querySelector('.cursor-dot');
  if(ring && dot){
    var tx=innerWidth/2, ty=innerHeight/2, rx=tx, ry=ty;
    window.addEventListener('pointermove',function(e){
      tx=e.clientX; ty=e.clientY;
      dot.style.setProperty('--dx',tx+'px'); dot.style.setProperty('--dy',ty+'px');
      ring.classList.add('show'); dot.classList.add('show');
    },{passive:true});
    (function loop(){
      rx+=(tx-rx)*0.18; ry+=(ty-ry)*0.18;
      ring.style.setProperty('--cx',rx.toFixed(1)+'px'); ring.style.setProperty('--cy',ry.toFixed(1)+'px');
      requestAnimationFrame(loop);
    })();
    document.querySelectorAll('a,button,.btn').forEach(function(el){
      el.addEventListener('pointerenter',function(){ring.classList.add('hot')});
      el.addEventListener('pointerleave',function(){ring.classList.remove('hot')});
    });
  }

  /* 3 · Botones magnéticos (micro-interacción con física) */
  document.querySelectorAll('.btn').forEach(function(btn){
    var s=16;
    btn.addEventListener('pointermove',function(e){
      var r=btn.getBoundingClientRect();
      var mx=(e.clientX-(r.left+r.width/2))/r.width, my=(e.clientY-(r.top+r.height/2))/r.height;
      btn.style.transform='translate('+(mx*s).toFixed(1)+'px,'+(my*s).toFixed(1)+'px)';
    });
    btn.addEventListener('pointerleave',function(){ btn.style.transform=''; });
  });
})();
</script>
</body>
</html>
