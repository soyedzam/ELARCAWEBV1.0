<script is:inline>
(function(){
  var rm = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // hero: cursor-reactive aurora (parallax de profundidad)
  var hero = document.querySelector('.hero');
  if(hero && !rm && window.matchMedia('(pointer:fine)').matches){
    hero.addEventListener('pointermove', function(e){
      var r = hero.getBoundingClientRect();
      var x = ((e.clientX - r.left)/r.width*100);
      var y = ((e.clientY - r.top)/r.height*100);
      hero.style.setProperty('--mx', x.toFixed(1)+'%');
      hero.style.setProperty('--my', (28 + y*0.18).toFixed(1)+'%');
    });
  }

  // hero: parallax sutil al scroll
  var sea = document.querySelector('.sea');
  if(sea && !rm){
    window.addEventListener('scroll', function(){
      var y = window.scrollY || 0;
      if(y < window.innerHeight){ sea.style.transform = 'translateY(' + (y*0.18) + 'px)'; }
    }, {passive:true});
  }

  // hero: pavesas de luz ascendentes
  var em = document.getElementById('embers');
  if(em && !rm){
    var N = window.innerWidth < 640 ? 14 : 26;
    for(var i=0;i<N;i++){
      var s = document.createElement('span'); s.className='ember';
      var dur = 7 + Math.random()*9, delay = -Math.random()*16, size = 2 + Math.random()*2.5;
      s.style.left = (Math.random()*100)+'%';
      s.style.width = s.style.height = size+'px';
      s.style.animationDuration = dur+'s';
      s.style.animationDelay = delay+'s';
      s.style.setProperty('--drift', (Math.random()*60-30)+'px');
      em.appendChild(s);
    }
  }

  // scroll reveal
  if(!rm && 'IntersectionObserver' in window){
    var io = new IntersectionObserver(function(es){
      es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
    }, {threshold:.16, rootMargin:'0px 0px -8% 0px'});
    document.querySelectorAll('.rv').forEach(function(el){ io.observe(el); });
  } else {
    document.querySelectorAll('.rv').forEach(function(el){ el.classList.add('in'); });
  }

  // nav solidify + waterline progress
  var nav = document.getElementById('nav'), wl = document.getElementById('wl');
  function onScroll(){
    var y = window.scrollY || document.documentElement.scrollTop;
    if(y > 40) nav.classList.add('solid'); else nav.classList.remove('solid');
    var h = document.documentElement.scrollHeight - window.innerHeight;
    wl.style.height = (h>0 ? (y/h*100) : 0) + 'vh';
  }
  window.addEventListener('scroll', onScroll, {passive:true}); onScroll();

  // FAQ accordion
  document.querySelectorAll('.qa button').forEach(function(btn){
    btn.addEventListener('click', function(){
      var qa = btn.closest('.qa'); var open = qa.classList.contains('open');
      qa.classList.toggle('open', !open);
      btn.setAttribute('aria-expanded', String(!open));
    });
  });
})();
</script>
<script is:inline>
(function(){
  var rm = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(rm) return; // fallback CSS estático ya cubre reduced-motion

  var scene = document.getElementById('scene');
  var vid = document.getElementById('arcaVid');
  if(!scene || !vid) return;

  var beats = Array.prototype.slice.call(scene.querySelectorAll('.beat'));
  // rangos de aparición por progreso de scroll (0..1)
  var ranges = [[0.00,0.20],[0.26,0.46],[0.52,0.72],[0.78,1.01]];

  var duration = 0, targetT = 0, curT = 0, ready = false, raf = null;

  function onMeta(){ duration = vid.duration || 6; ready = true; }
  if(vid.readyState >= 1){ onMeta(); } else { vid.addEventListener('loadedmetadata', onMeta); }

  // "primar" el video en iOS/Safari para permitir el seek
  function prime(){ var p = vid.play(); if(p && p.then){ p.then(function(){ vid.pause(); }).catch(function(){}); } }
  window.addEventListener('touchstart', prime, {once:true, passive:true});
  window.addEventListener('click', prime, {once:true});
  vid.addEventListener('canplay', function(){ try{ vid.pause(); }catch(e){} });

  function progress(){
    var rect = scene.getBoundingClientRect();
    var total = scene.offsetHeight - window.innerHeight;
    var p = total > 0 ? (-rect.top / total) : 0;
    return Math.max(0, Math.min(1, p));
  }

  function tick(){
    // suavizado (lerp) hacia el tiempo objetivo => scrubbing tipo Apple
    curT += (targetT - curT) * 0.12;
    if(ready && Math.abs(targetT - curT) > 0.001){
      try{ vid.currentTime = curT; }catch(e){}
    }
    raf = requestAnimationFrame(tick);
  }

  function update(){
    var p = progress();
    if(ready){ targetT = Math.min(duration - 0.05, p * duration); }
    beats.forEach(function(b,i){
      var r = ranges[i]; var on = p >= r[0] && p < r[1];
      b.classList.toggle('on', on);
    });
    scene.classList.toggle('ended', p > 0.12);
  }

  window.addEventListener('scroll', update, {passive:true});
  window.addEventListener('resize', update);
  update();
  raf = requestAnimationFrame(tick);
})();
</script>
